<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050816">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp"
        android:splitMotionEvents="true">

        <TextView
            android:id="@+id/tv_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="阶段 1"
            android:textColor="#FDE68A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.example.nighttrace.NightTraceView
            android:id="@+id/night_trace_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_pause_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="48dp"
        android:backgroundTint="#CC0F172A"
        android:text="Ⅱ"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/pause_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9050816"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="暂停"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_resume"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#0EA5E9"
            android:text="继续"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_restart_menu"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#FACC15"
            android:text="重新开始"
            android:textColor="#111827"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_home"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#334155"
            android:text="回到主页面"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/start_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/start_cover" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#69050816"
            android:gravity="top|center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="64dp"
            android:paddingEnd="28dp"
            android:paddingBottom="42dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="夜幕疾影"
                android:textColor="#F8FAFC"
                android:textSize="40sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_start_hero"
                android:layout_width="230dp"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:backgroundTint="#FACC15"
                android:text="开始游戏"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
